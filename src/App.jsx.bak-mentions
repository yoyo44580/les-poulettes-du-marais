                { value: "kennel", label: "Pension canine" },
                { value: "clients", label: "Clients" },
                { value: "contacts", label: "Messages" },
                { value: "announcements", label: "Annonces" },
                { value: "accounting", label: "Comptabilité" },
                { value: "content", label: "Présentation" },
              ].map((tab) => (
                <button

                      onChange={(e) => setKennelBookingForm({ ...kennelBookingForm, startDate: e.target.value })}
                    />
                  </label>
                  <label>
                    <span>Départ</span>
                    <input
                      type="date"
                      min={kennelBookingForm.startDate || getLocalIsoDate()}

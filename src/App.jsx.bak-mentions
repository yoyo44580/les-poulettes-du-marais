                  />
                </label>

                <button type="submit" className="primary-action">
                  Envoyer la demande
                </button>
              </form>
            </div>
          </section>
        )}

        {screen === "contact" && (
          <section className="service-page">
            <div className="service-hero service-hero--contact">

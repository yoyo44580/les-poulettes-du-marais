                  ))}
                  <article>
                    <CalendarDays size={22} />
                    <div>
                      <strong>Dates du séjour</strong>
                      <p>Indiquez l'arrivée et le départ pour vérifier les disponibilités.</p>
                    </div>
                  </article>
                  <article>
                    <Dog size={22} />

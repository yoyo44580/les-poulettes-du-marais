  const total = useMemo(() => {
    return products.reduce((sum, p) => sum + (cart[p.id] || 0) * p.price, 0);
  }, [cart, products]);

  const totalEggs = useMemo(() => {
    return products.reduce((sum, p) => {
      if (!isEggProduct(p)) {
        return sum;
      }

      return sum + (cart[p.id] || 0) * (p.size_eggs || 0);
    }, 0);
  }, [cart, products]);

  const selectedCartItems = useMemo(() => {
    return products

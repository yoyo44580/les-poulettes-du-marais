                            <span>{getOrderSummary(order)}</span>
                            <strong>{getOrderEggs(order)} śufs</strong>
                          </div>
                        </div>
                      ))}
                    </div>
                  </article>
                ))}

                {eggSummaryPlanning.length === 0 && (
                  <div className="egg-summary-empty">Aucune commande d'śufs ŕ venir pour le moment.</div>
                )}
              </div>
            </>
          )}
        </section>
      </main>
    );
  }

  return (
    <div className="min-h-screen bg-amber-50 text-stone-900">

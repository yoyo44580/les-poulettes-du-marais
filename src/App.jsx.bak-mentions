  useEffect(() => {
    if (!canUseBrowser || !("serviceWorker" in navigator)) {
      return;
    }

    const showNotice = () => setShowUpdateNotice(true);

    window.addEventListener("pwa-update-available", showNotice);
    navigator.serviceWorker.addEventListener("controllerchange", showNotice);

    return () => {
      window.removeEventListener("pwa-update-available", showNotice);
      navigator.serviceWorker.removeEventListener("controllerchange", showNotice);
    };
  }, []);

  useEffect(() => {
    const timer = window.setTimeout(() => {
      void loadAboutContent();
    }, 0);

    return () => window.clearTimeout(timer);
  }, [loadAboutContent]);

  const loadEducationActivities = useCallback(async () => {
